{
  "id": "DAG",
  "name": "DAG",
  "type": "DAG",
  "icon": "account_tree",
  "category": "airflow",
  "description": "Contenedor principal de flujo de Airflow",
  "framework": "airflow",
  "platform": "airflow",
  "template": "dag",
  "isDefaultFavorite": true,
  "isActive": true,
  "importLiteral": "from airflow import DAG",
  "parameters": {
    "dag_id": {
      "type": "string",
      "default": "my_dag",
      "description": "Identificador único del DAG"
    },
    "owner": {
      "type": "string",
      "default": "airflow",
      "description": "Propietario del DAG (default_args)"
    },
    "depends_on_past": {
      "type": "boolean",
      "default": false,
      "description": "Depender de la ejecución previa (default_args)"
    },
    "start_date": {
      "type": "string",
      "default": "2024-01-01",
      "description": "Fecha de inicio (YYYY-MM-DD)"
    },
    "start_date_timezone": {
      "type": "string",
      "default": "America/Mexico_City",
      "description": "Zona horaria para start_date (pendulum timezone)"
    },
    "email": {
      "type": "string",
      "default": "",
      "description": "Correo para alertas (default_args)"
    },
    "email_on_failure": {
      "type": "boolean",
      "default": false,
      "description": "Enviar email en fallo (default_args)"
    },
    "email_on_retry": {
      "type": "boolean",
      "default": false,
      "description": "Enviar email en retry (default_args)"
    },
    "retries": {
      "type": "integer",
      "default": 1,
      "description": "Número de reintentos (default_args)"
    },
    "retry_delay": {
      "type": "integer",
      "default": 5,
      "description": "Delay entre reintentos en minutos (default_args)"
    },
    "schedule_interval": {
      "type": "string",
      "default": "@daily",
      "description": "Expresión cron o preset (@daily, @hourly, etc.)"
    },
    "catchup": {
      "type": "boolean",
      "default": false,
      "description": "Ejecutar tareas pasadas"
    },
    "tags": {
      "type": "array",
      "default": [],
      "description": "Etiquetas del DAG"
    },
    "description": {
      "type": "string",
      "default": "",
      "description": "Descripción del DAG"
    },
    "dagrun_timeout": {
      "type": "integer",
      "default": 80,
      "description": "Timeout de ejecución del DAG en minutos"
    },
    "concurrency": {
      "type": "integer",
      "default": 1,
      "description": "Cantidad máxima de tasks ejecutando en paralelo"
    },
    "max_active_runs": {
      "type": "integer",
      "default": 1,
      "description": "Cantidad máxima de DAG runs activos"
    },
    "user_defined_macros": {
      "type": "object",
      "default": {},
      "description": "Macros personalizadas del DAG"
    }
  }
}
